# ========================================================================
# TrueKit — environment variables
# Copy to `.env.local` (kept out of git) and fill in real values.
# ========================================================================

# -- Supabase ------------------------------------------------------------
# Project Settings -> API -> Project URL + anon public key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Project Settings -> API -> service_role secret (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# -- Database (Supabase Postgres) ---------------------------------------
# Project Settings -> Database -> Connection string
# Use the pooler URL (port 6543) for DATABASE_URL,
# and the direct URL (port 5432) for DIRECT_URL — Prisma migrations need it.
DATABASE_URL=
DIRECT_URL=

# -- Stripe --------------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Local: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# prints a signing secret. Vercel: copy from the dashboard webhook config.
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# -- App -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Auth feature flags --------------------------------------------------
# Set to `true` once Google OAuth is configured in both Google Cloud Console
# and the Supabase Authentication → Providers panel. Until then, the
# "Continue with Google" button stays hidden so users don't click a broken flow.
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false

# -- Email (Resend) ------------------------------------------------------
RESEND_API_KEY=
